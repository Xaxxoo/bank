# App
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=pulse_mfb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# HMAC
HMAC_TIMESTAMP_TOLERANCE_MS=300000

# BaaS Provider (Anchor)
# Anchor sandbox: https://sandbox.api.getanchor.co
# Anchor production: https://api.getanchor.co
ANCHOR_BASE_URL=https://sandbox.api.getanchor.co
ANCHOR_API_KEY=your_anchor_api_key

# SMS (Termii)
TERMII_SMS_BASE_URL=https://api.ng.termii.com
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=PulseMFB

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@pulsemfb.com
SMTP_PASS=your_smtp_password
